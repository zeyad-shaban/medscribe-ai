{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server: Next.js",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    },
    {
      "name": "Client: Brave Attach",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "http://localhost:3000/*",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Brave Attach)",
      "configurations": ["Server: Next.js", "Client: Brave Attach"]
    }
  ]
}